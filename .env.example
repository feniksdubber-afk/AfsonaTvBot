# ─────────────────────────────────────────────────────────────────
# AfsonaTvBot — muhit o'zgaruvchilari
# DIQQAT: Bu faylni hech qachon GitHub/public joyga yuklamang!
#         .gitignore ga .env qo'shilganligini tekshiring.
# Namuna: .env.example faylini ko'ring
# ─────────────────────────────────────────────────────────────────

# Telegram Bot tokeni (@BotFather dan oling)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin(lar) Telegram ID si — vergul bilan ajratilib yoziladi
ADMINS=YOUR_TELEGRAM_ID_HERE

# Majburiy obuna kanali (public — @username ko'rinishida)
CHANNEL_PUBLIC=@your_channel_username

# Majburiy obuna kanali (private — -100... ko'rinishida)
CHANNEL_PRIVATE=-1000000000000

# Ma'lumotlar bazasi fayl yo'li
DB_PATH=data/kinobot.db

# ─── To'lov tizimlari (ixtiyoriy) ────────────────────────────────
# Click to'lov integratsiyasi uchun
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# Payme to'lov integratsiyasi uchun
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
